{
  "rules": {
    ".read": false,
    ".write": false,

    "rooms": {
      "$roomCode": {
        // Room codes are the access secret (5 random chars, unguessable, not listable
        // since there's no read rule on the bare "rooms" node) — any signed-in client
        // that knows the code can read the room, anonymous auth included.
        ".read": "auth != null",

        // Governs whole-room writes: creating a brand-new room (must self-declare as
        // host) or any host-driven transition (settings, round assignment, status
        // changes, rematch reset, room deletion on host leave).
        ".write": "auth != null && (data.exists() ? data.child('hostId').val() === auth.uid : newData.child('hostId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['hostId', 'status', 'settings', 'users'])",

        "hostId": { ".validate": "newData.isString()" },

        "status": {
          ".validate": "newData.val() === 'lobby' || newData.val() === 'playing' || newData.val() === 'voting' || newData.val() === 'defense' || newData.val() === 'reveal'"
        },

        "settings": {
          ".validate": "newData.hasChildren(['categoryId', 'mode'])",
          "categoryId": { ".validate": "newData.isString()" },
          "mode": { ".validate": "newData.val() === 'normal' || newData.val() === 'hard'" }
        },

        "users": {
          "$uid": {
            // A player manages only their own seat (join/update/leave); the host can
            // also touch any seat via the room-root rule above. The 8-player cap is
            // enforced client-side (MainScreen checks the count before joining) —
            // the console rules linter chokes on numChildren() through a .parent()
            // chain, so we don't duplicate that check here.
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['nickname', 'avatar', 'isHost', 'joinedAt', 'ready'])",

            "nickname": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 10" },
            "ready": { ".validate": "newData.isBoolean()" },
            "avatar": {
              ".validate": "newData.hasChildren(['eyes', 'mouth', 'theme'])",
              "eyes": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 7" },
              "mouth": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 7" },
              "theme": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 7" }
            }
          }
        },

        "reactions": {
          "$uid": {
            // A short-lived emoji broadcast above the sender's own player card;
            // clients expire it locally after ~2s, so no cleanup write is needed.
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['emoji', 'ts']) && newData.child('emoji').isString() && newData.child('ts').isNumber()"
          }
        },

        // Only ever written by the host (round assignment on start, cleared on
        // rematch) — no dedicated child rule needed, it rides the room-root rule.
        "round": {
          ".validate": "newData.hasChildren(['categoryId', 'categoryName', 'mode', 'liarIds', 'wordByUser', 'word', 'endsAt'])"
        },

        // Only ever written by the host (set when voting ends with a non-tied top
        // vote, cleared on rematch) — rides the room-root rule, same as "round".
        "defense": {
          ".validate": "newData.hasChildren(['topVotedId', 'endsAt'])"
        },

        "votes": {
          "$voterUid": {
            // Each player casts only their own vote, and can't vote for themselves.
            // newData.parent().parent() walks votes/$voterUid -> votes -> $roomCode.
            ".write": "auth != null && auth.uid === $voterUid",
            ".validate": "newData.isString() && newData.val() !== $voterUid && newData.parent().parent().child('users').hasChild(newData.val())"
          }
        },

        "chat": {
          "$msgId": {
            // Append-only log: a message can be created by its author, never edited
            // or deleted afterwards (data.exists() is false only on first write).
            ".write": "auth != null && !data.exists() && newData.child('userId').val() === auth.uid",
            ".validate": "newData.hasChildren(['userId', 'nickname', 'text', 'ts'])",
            "text": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
            "nickname": { ".validate": "newData.isString() && newData.val().length <= 10" },
            "ts": { ".validate": "newData.isNumber()" }
          }
        },

        "result": {
          // Host can always write result (creating it at reveal time, clearing it on
          // rematch) — data.parent() is the $roomCode node, so .child('hostId') reads
          // the room's host regardless of whether "result" exists yet. Separately,
          // the one player who got caught (topVotedId) can submit their own
          // word-guess exactly once, before winner is decided — this has to be its
          // own clause because it's the only path a non-host client legitimately
          // writes to under "result". ".val()" on winner would be a string/null, and
          // "!" only works on booleans, so we check ".exists()" instead.
          ".write": "auth != null && (data.parent().child('hostId').val() === auth.uid || (data.child('liarCaught').val() === true && !data.child('winner').exists() && auth.uid === data.child('topVotedId').val()))",
          "winner": { ".validate": "newData.val() === 'citizens' || newData.val() === 'liars'" }
        }
      }
    }
  }
}
